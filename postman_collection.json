{
	"info": {
		"_postman_id": "vulnerable-api-lab-collection",
		"name": "Vulnerable API Lab",
		"description": "Collection for testing the Vulnerable API Lab environment.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "General",
			"item": [
				{
					"name": "Get Landing Page",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/",
							"host": [
								"{{base_url}}"
							],
							"path": [
								""
							]
						}
					},
					"response": []
				},
				{
					"name": "Get Help Page",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/help",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"help"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Auth",
			"item": [
				{
					"name": "Get Token",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"admin\",\n  \"password\": \"password\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/tokens",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"tokens"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Vulnerable Endpoints",
			"item": [
				{
					"name": "Eval (Simulated Injection)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/eval?s=test",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"eval"
							],
							"query": [
								{
									"key": "s",
									"value": "test"
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "XML User Search (XXE)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/xml",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "<?xml version=\"1.0\" encoding=\"UTF-8\" ?>\n<root>\n  <user>admin</user>\n</root>"
						},
						"url": {
							"raw": "{{base_url}}/search",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"search"
							]
						}
					},
					"response": []
				},
				{
					"name": "Uptime Check (Cmd Injection)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/uptime/;id",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"uptime",
								";id"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "User Management",
			"item": [
				{
					"name": "Create User",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "X-Auth-Token",
								"value": "{{admin_token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"newuser\",\n  \"password\": \"newpass\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/user",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"user"
							]
						}
					},
					"response": []
				},
				{
					"name": "Get User Details (IDOR)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X-Auth-Token",
								"value": "{{admin_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/user/admin",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"user",
								"admin"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Widget Management",
			"item": [
				{
					"name": "Create Widget",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "X-Auth-Token",
								"value": "{{admin_token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"widget1\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/widget",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"widget"
							]
						}
					},
					"response": []
				}
			]
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:5000",
			"type": "string"
		},
		{
			"key": "admin_token",
			"value": "your-token-here",
			"type": "string"
		}
	]
}
